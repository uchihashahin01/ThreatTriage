# ─── ThreatTriage Configuration ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=ThreatTriage
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-to-a-random-secret-key

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://threattriage:threattriage@localhost:5432/threattriage
# SQLite (local dev — uncomment to use)
# DATABASE_URL=sqlite+aiosqlite:///./threattriage.db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Threat Intelligence API Keys ─────────────────────────────────────────────
# Get free keys:
#   VirusTotal:   https://www.virustotal.com/gui/join-us
#   AlienVault:   https://otx.alienvault.com/api
#   AbuseIPDB:    https://www.abuseipdb.com/register
VIRUSTOTAL_API_KEY=
ALIENVAULT_API_KEY=
ABUSEIPDB_API_KEY=

# ─── Feature Flags ────────────────────────────────────────────────────────────
DEMO_MODE=true
ENABLE_TI_ENRICHMENT=true
ENABLE_ANOMALY_DETECTION=true

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=threat-triage-dev-key
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
